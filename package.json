{
  "name": "learn.ai.video",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "sync:scene3": "bash scripts/sync-scene3-assets.sh",
    "sync:scene4": "bash scripts/sync-scene4-assets.sh",
    "sync:scene6": "bash scripts/sync-scene6-assets.sh",
    "sync:scene7": "bash scripts/sync-scene7-assets.sh",
    "sync:scene8": "bash scripts/sync-scene8-assets.sh",
    "sync:scene_listen": "bash scripts/sync-scene-listen-assets.sh",
    "sync:store": "bash scripts/sync-scene3-assets.sh && bash scripts/sync-scene4-assets.sh && bash scripts/sync-scene6-assets.sh && bash scripts/sync-scene7-assets.sh && bash scripts/sync-scene8-assets.sh && bash scripts/sync-scene-listen-assets.sh",
    "start": "npx remotion studio src/index.ts",
    "render": "npx remotion render Scene1 out/scene1.mp4",
    "render:light": "npx remotion render Scene1 out/scene1-light.mp4 --props='{\"theme\":\"light\",\"locale\":\"en-US\"}'",
    "render:all": "node scripts/render-all.js",
    "render:all:en": "node scripts/render-all.js --locale en-US",
    "render:all:light": "node scripts/render-all.js --theme light",
    "tts:prompts": "node scripts/voice-prompts-from-json.mjs",
    "tts:prompts:all-locales": "node scripts/voice-prompts-from-json.mjs --all-locales",
    "tts:generate-unique": "node scripts/tts-generate-unique.mjs",
    "tts:generate-unique:dry": "node scripts/tts-generate-unique.mjs --dry-run",
    "tts:generate-unique:force": "node scripts/tts-generate-unique.mjs --force",
    "audio:sync-config": "node scripts/audio-config-sync.mjs",
    "tts:all": "npm run tts:prompts && npm run tts:generate-unique && npm run audio:sync-config",
    "render:fullvideo:all": "node scripts/render-fullvideo-all.cjs",
    "render:fullvideo:all:upload:public": "node scripts/render-fullvideo-all.cjs --theme both --skip-existing --then-upload --upload-privacy public",
    "youtube:config:sync": "node scripts/sync-youtube-videos-config.cjs",
    "youtube:oauth": "node scripts/youtube-oauth-init.cjs",
    "youtube:upload": "node scripts/youtube-upload.cjs",
    "youtube:upload:dry": "node scripts/youtube-upload.cjs --dry-run",
    "youtube:thumbnails:apply": "node scripts/youtube-thumbnails-apply.cjs",
    "youtube:playlist:sync": "node scripts/youtube-playlist-sync.cjs",
    "youtube:publish": "node scripts/youtube-videos-publish.cjs",
    "youtube:metadata:sync": "node scripts/youtube-videos-sync-metadata.cjs",
    "youtube:thumbnail": "node scripts/generate-youtube-thumbnail.cjs",
    "youtube:thumbnail:all": "node scripts/generate-youtube-thumbnail.cjs --all"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "sharp": "^0.34.1",
    "typescript": "^6.0.2"
  },
  "dependencies": {
    "@remotion/cli": "^4.0.443",
    "@remotion/google-fonts": "^4.0.443",
    "@remotion/media": "^4.0.443",
    "googleapis": "^171.4.0",
    "open": "^11.0.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-qr-code": "^2.0.18",
    "remotion": "^4.0.443"
  }
}
